{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Port=3306;Database=risk_analyzer_db;Uid=YOUR_USER;Pwd=YOUR_PASSWORD;"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_MINIMUM_32_CHARACTERS_LONG",
    "ExpirationMinutes": 60,
    "Issuer": "RiskAnalyzerApi",
    "Audience": "RiskAnalyzerApp"
  },
  "GeminiSettings": {
    "ApiKey": "YOUR_GEMINI_API_KEY_HERE",
    "ModelId": "gemini-2.0-flash",
    "MaxAttemptsPerImage": 3,
    "TimeoutSeconds": 30
  },
  "FileUpload": {
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": ".jpg,.jpeg,.png,.webp,.gif",
    "StoragePath": "uploads"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:4200,http://localhost:3000",
    "AllowedMethods": "GET,POST,PUT,DELETE,OPTIONS",
    "AllowedHeaders": "Content-Type,Authorization"
  }
}
