# API Configuration
# Set to your local or production API server URL
ANGULAR_APP_API_URL=http://localhost:5193/api
ANGULAR_APP_PRODUCTION=false

# Token Storage
# Key name for storing JWT token in localStorage
ANGULAR_APP_TOKEN_STORAGE_KEY=auth_token

# File Upload Settings (in bytes)
ANGULAR_APP_MAX_FILE_SIZE=10485760
ANGULAR_APP_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif,bmp
ANGULAR_APP_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,image/bmp

# API Endpoints
ANGULAR_APP_AUTH_ENDPOINT=/auth
ANGULAR_APP_UPLOAD_ENDPOINT=/imageanalysis
ANGULAR_APP_ANALYSIS_ENDPOINT=/imageanalysis

# Gemini AI Settings (Client-side)
# Risk score threshold for flagging images as high risk (0-100)
ANGULAR_APP_GEMINI_RISK_THRESHOLD=50
